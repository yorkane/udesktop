# Desktop Configuration
REMOTE_DESKTOP=novnc
USER=ubuntu
PASSWORD=ubuntu
VNC_RESOLUTION=1280x1024
DISABLE_HTTPS=1

# Chrome Configuration
CHROME_AUTO_START=1
CHROME_URL=https://www.google.com

# Proxy Configuration
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,.example.com

# Chrome Specific Proxy (if different from system)
# CHROME_PROXY_SERVER=http://proxy.example.com:8080
# CHROME_NO_PROXY=localhost,127.0.0.1,.example.com

# S3 Configuration (Optional - for mounting S3 bucket)
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=your_bucket
